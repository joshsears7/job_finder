# CareerIQ — Environment Variables
# Copy this file to .env and fill in your keys. Never commit .env to version control.

# Required — AI features (resume scoring, cover letters, interview prep)
ANTHROPIC_API_KEY=sk-ant-...

# Required for cloud deployment — PostgreSQL connection string (get from neon.tech)
# Leave blank to use SQLite locally
DATABASE_URL=

# Optional — Job search (Adzuna provides live job listings)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional — Additional job listings via RapidAPI JSearch
JSEARCH_API_KEY=

# Optional — Market intelligence (FRED economic data)
FRED_KEY=

# Optional — GitHub trending data (increases rate limit from 60/hr to 5,000/hr; free at github.com/settings/tokens)
GITHUB_TOKEN=

# Optional — Internal API authentication (server-to-server calls)
CAREERIQ_API_KEY=
